# Groq API Key (required) — Get free at https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here

# LLM Model (optional, default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Differential Privacy epsilon (optional, default: 1.0)
DP_EPSILON=1.0

# MLflow tracking URI (optional, default: file-based ./mlruns)
MLFLOW_TRACKING_URI=file:./mlruns

# ChromaDB persist directory (optional)
CHROMA_PERSIST_DIR=./chroma_data

# Vault data directory (optional)
VAULT_DATA_DIR=./vault_data

# Use fine-tuned NER model (set to true after running train_ner.py)
USE_TRAINED_NER=false
